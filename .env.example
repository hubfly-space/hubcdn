# Copy to .env and adjust. Used by docker-compose.yml.

# --- Required ---
HUBCDN_ACME_EMAIL=ops@hubcdn.space
HUBCDN_PUBLIC_IPS=41.186.167.39
HUBCDN_HOSTNAME=cdn.hubcdn.space

# --- TLS ---
# Set to true while testing so you don't burn production ACME quota.
HUBCDN_ACME_STAGING=false

# --- Ports ---
# Container-internal listen ports (passed to the app as HUBCDN_HTTP_ADDR /
# HUBCDN_HTTPS_ADDR). Both are unprivileged (>1024) so the container never
# needs root or CAP_NET_BIND_SERVICE.
HUBCDN_HTTP_PORT=8080
HUBCDN_HTTPS_PORT=4403

# Host-side ports docker-compose publishes these to. Point your external
# port 80/443 (firewall NAT, router, or reverse proxy) at these — compose
# itself does not need to publish 80/443 directly.
HUBCDN_HOST_HTTP_PORT=8080
HUBCDN_HOST_HTTPS_PORT=4403

# --- Optional ---
# HUBCDN_RESOLVER=1.1.1.1:53
# HUBCDN_CACHE_MAX_BYTES=1gb
# HUBCDN_CACHE_MAX_OBJECT_BYTES=32mb
# HUBCDN_BUNNY_API_KEY=
# HUBCDN_BUNNY_ZONE_ID=
