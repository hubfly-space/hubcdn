# Copy to .env and adjust. Used by docker-compose.yml.

# --- Required ---
HUBCDN_ACME_EMAIL=ops@hubcdn.space
HUBCDN_PUBLIC_IPS=41.186.167.39
HUBCDN_HOSTNAME=cdn.hubcdn.space

# --- TLS ---
# Set to true while testing so you don't burn production ACME quota.
HUBCDN_ACME_STAGING=false

# --- Port ---
# hubCDN is TLS-only — there is no HTTP port. Container-internal listen
# port (passed to the app as HUBCDN_HTTPS_ADDR); unprivileged (>1024) so the
# container never needs root or CAP_NET_BIND_SERVICE.
HUBCDN_HTTPS_PORT=4403

# Host-side port docker-compose publishes this to. Point your external
# port 443 (firewall NAT, router, or reverse proxy) at it — compose itself
# does not need to publish 443 directly. Note: the ACME TLS-ALPN-01
# challenge is always validated against port 443 specifically, so whatever
# you forward as "your public 443" must reach this port.
HUBCDN_HOST_HTTPS_PORT=4403

# --- Optional ---
# HUBCDN_RESOLVER=1.1.1.1:53
# HUBCDN_CACHE_MAX_BYTES=1gb
# HUBCDN_CACHE_MAX_OBJECT_BYTES=32mb
# HUBCDN_BUNNY_API_KEY=
# HUBCDN_BUNNY_ZONE_ID=
